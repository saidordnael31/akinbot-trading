# OKX integration
# Demo mode is mandatory during the current recovery phase.
OKX_MODE=demo

# Set the REST host that applies to the OKX account region.
# Common official hosts include https://www.okx.com and https://eea.okx.com.
OKX_BASE_URL=https://www.okx.com

# Create these values directly in the deployment secret manager.
# Never commit actual credentials or send them through chat.
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# Safety controls. Trading is not implemented in the current connector.
OKX_ENABLE_PRIVATE_READS=true
OKX_ENABLE_ORDER_WRITES=false
