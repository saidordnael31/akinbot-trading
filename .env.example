# OKX integration
# Demo mode is mandatory. Production mode is blocked in code.
OKX_MODE=demo

# Official OKX demo REST host for this integration.
OKX_BASE_URL=https://eea.okx.com

# Configure these values directly in the deployment secret manager.
# Never commit actual credentials.
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# Private reads
OKX_ENABLE_PRIVATE_READS=true

# Demo order writes remain disabled until every control below is configured.
OKX_ENABLE_ORDER_WRITES=false

# Default-on emergency lock. Set false only for a controlled demo test.
OKX_TRADING_KILL_SWITCH=true

# Secret token required in the x-akin-order-token header.
OKX_INTERNAL_ORDER_TOKEN=

# Initial allowlist: USDT-quoted spot only.
OKX_ALLOWED_INSTRUMENTS=BTC-USDT,ETH-USDT

# Stateless pre-trade limits.
OKX_MAX_ORDER_NOTIONAL_USDT=25
OKX_MAX_LIMIT_DEVIATION_BPS=500

# OKX Cancel All After protection: integer from 10 to 120 seconds.
OKX_CANCEL_ALL_AFTER_SECONDS=30
